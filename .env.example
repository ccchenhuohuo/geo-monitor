# 复制为 .env 后填写真实密钥；不要提交 .env。
LLM_API_KEY=
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=provider-model

# Native providers use official endpoints by default; provider-specific keys override the LLM_API_KEY fallback.
ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DASHSCOPE_API_KEY=
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

WEB_SEARCH_LIMIT=5
MAX_TOOL_CALLS=2
REQUEST_TIMEOUT_SECONDS=90
RETRY_MAX_ATTEMPTS=3
CONCURRENCY=1
MAX_OUTPUT_TOKENS=2000
ANALYSIS_MAX_OUTPUT_TOKENS=4000
ANALYSIS_MAX_CANONICAL_NAMES=500
ANALYSIS_MAX_CANONICAL_CHARS=50000
MAX_JOB_UNITS=10000
MAX_CONSECUTIVE_ERRORS=5
MAX_ERROR_RATE=0.5
ALLOW_INSECURE_HTTP=false
