{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GEO Monitor Job Config",
  "description": "Job config supports two runtime modes: inline query mode with queries in this JSON file, and external manifest mode where the CLI/API call also provides --query-manifest/query_manifest_path. Schema validity alone does not prove an external-manifest config can run without that runtime argument.",
  "type": "object",
  "additionalProperties": false,
  "required": ["target_brand", "industry"],
  "properties": {
    "target_brand": {
      "type": "string",
      "minLength": 1
    },
    "target_aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "owned_domains": {
      "description": "Optional canonical domains owned by the target brand, without scheme, port, path, query, or credentials.",
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^(?!.*://)(?!.*[/@?#:])[^\\s]+$"
      },
      "default": []
    },
    "industry": {
      "type": "string",
      "minLength": 1
    },
    "market": {
      "type": "string",
      "description": "Optional market or region. Omit it for non-regional brands."
    },
    "queries": {
      "description": "Inline queries for legacy/local jobs. Optional when the CLI/API call provides an external --query-manifest.",
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": true,
            "anyOf": [
              {
                "required": ["query"]
              },
              {
                "required": ["text"]
              }
            ],
            "properties": {
              "query_id": {
                "type": "string",
                "minLength": 1
              },
              "query": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "persona": {
                "type": "string"
              },
              "stage": {
                "type": "string"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        ]
      }
    },
    "repeats": {
      "description": "Positive integer. Runtime also accepts integer-like strings for CLI/agent convenience.",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "number",
          "minimum": 1,
          "multipleOf": 1
        },
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        }
      ],
      "default": 20
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "adapter": {
      "type": "string",
      "enum": [
        "openai_responses_web_search",
        "doubao_responses_web_search",
        "qwen_responses_web_search_basic",
        "qwen_chat_enable_search"
      ],
      "default": "openai_responses_web_search"
    },
    "adapter_options": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    },
    "analysis_model": {
      "type": "string",
      "minLength": 1
    },
    "analysis_adapter": {
      "type": "string",
      "enum": ["openai_responses_text"],
      "default": "openai_responses_text"
    },
    "web_search_limit": {
      "description": "Integer from 1 to 20. Runtime also accepts integer-like strings for CLI/agent convenience.",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        {
          "type": "number",
          "minimum": 1,
          "maximum": 20,
          "multipleOf": 1
        },
        {
          "type": "string",
          "pattern": "^([1-9]|1[0-9]|20)$"
        }
      ]
    },
    "concurrency": {
      "description": "Integer from 1 to 8. Runtime also accepts integer-like strings for CLI/agent convenience.",
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        {
          "type": "number",
          "minimum": 1,
          "maximum": 8,
          "multipleOf": 1
        },
        {
          "type": "string",
          "pattern": "^[1-8]$"
        }
      ]
    },
    "start_interval_seconds": {
      "type": "number",
      "minimum": 0,
      "default": 0
    }
  }
}
